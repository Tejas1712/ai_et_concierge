# Gemini API key for LLM calls (preferred)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name
GEMINI_MODEL=gemini-2.5-flash-lite

# Backward-compatible alias (optional if GEMINI_API_KEY is set)
GOOGLE_API_KEY=

GROQ_API_KEY=

# Optional absolute or relative path to catalog JSON
CATALOG_PATH=backend/data/et_catalog.json

# Frontend origins allowed by CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000

HF_TOKEN=

# Database URL (Neon/PostgreSQL cloud or local PostgreSQL)
# Example (Neon): postgresql+psycopg://<user>:<password>@<host>/<db>?sslmode=require
# Example (local): postgresql+psycopg://postgres:postgres@localhost:5432/et_agent
DATABASE_URL=

# JWT signing secret and token settings
JWT_SECRET=Vedant_has_a_god_complex
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# History + personalization runtime mode
HISTORY_BACKEND=postgres
